# Copy to .env.local and fill in your own values.

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Transactional email (Resend, used via Supabase SMTP)
RESEND_KEY=

# Rate limiting (Upstash Redis) — optional; routes no-op without it
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: post user feedback to a Discord channel
DISCORD_FEEDBACK_WEBHOOK_URL=
